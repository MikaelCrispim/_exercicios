# Exercicio 7
def tempConversor(grausCelsius):
    grausFahrenheit = (grausCelsius * (9/5)) + 32
    print(f"A temperatura {grausCelsius}C° em Fahrenheit é {grausFahrenheit}F°")

# Exercicio 8
def contadorVogal(fraseCompleta):
    vogais = ['a', 'e', 'i', 'o', 'u']
    cont = 0
    for letra in vogais:
        for caractere in fraseCompleta.lower():
            if letra == caractere:
                cont += 1
    print(f"A frase tem {cont} vogais")

# Exercicio 9
def calcularFatorial(numeroFatorial):
    if numeroFatorial == 0:
        numeroFatorial = 1
    else:
        for i in range(1, numeroFatorial):
            numeroFatorial *= i
    print(f"O fatorial é: {numeroFatorial}")

