# Exercicio 13
def calcularFibonacci(posicaoN):
    if posicaoN <= 0:
        return 0
    elif posicaoN == 1:
        return 1
    else:
        return calcularFibonacci(posicaoN - 1) + calcularFibonacci(posicaoN - 2)

