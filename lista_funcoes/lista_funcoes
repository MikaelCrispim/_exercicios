# Exercicio 11
def leiaInt(mensagemInput):
    while True:
        valor = input(mensagemInput)
        if valor.isnumeric() or (valor.startswith('-') and valor[1:].isnumeric()):
            return int(valor)
        print("Erro: Por favor, digite um número inteiro válido.")

