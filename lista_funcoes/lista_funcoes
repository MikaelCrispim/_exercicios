# Exercicio 15
def encontrarProdutoMaisCaro(listaProdutos):
    if not listaProdutos:
        return None
    produtoMaisCaro = listaProdutos[0]
    for produtoAtual in listaProdutos:
        if produtoAtual['preco'] > produtoMaisCaro['preco']:
            produtoMaisCaro = produtoAtual
    return produtoMaisCaro

